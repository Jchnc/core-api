<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Welcome</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f4f4f5;
        margin: 0;
        padding: 40px 16px;
      }
      .card {
        background: #fff;
        border-radius: 8px;
        max-width: 520px;
        margin: 0 auto;
        padding: 40px 32px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
      }
      h1 {
        font-size: 20px;
        color: #111;
        margin: 0 0 8px;
      }
      p {
        color: #555;
        font-size: 15px;
        line-height: 1.6;
        margin: 0 0 24px;
      }
    </style>
  </head>
  <body>
    <div class='card'>
      <h1>Welcome, {{name}}!</h1>
      <p>Your account has been created successfully. You can now log in and get started.</p>
    </div>
  </body>
</html>